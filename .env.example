BOT_TOKEN=
ALLOWED_TELEGRAM_USERNAMES=
PRIVATE_KEY=

# Default RPC used by old single-chain features.
DEFAULT_CHAIN=

# Multi-chain mint RPCs.
ETH_RPC_URL=
SEPOLIA_RPC_URL=
BASE_RPC_URL=
ARBITRUM_RPC_URL=
OPTIMISM_RPC_URL=
POLYGON_RPC_URL=
BSC_RPC_URL=

# Optional comma-separated fallback RPCs per chain. The single *_RPC_URL above
# still works and is used after these entries.
ETH_RPC_URLS=
SEPOLIA_RPC_URLS=
BASE_RPC_URLS=
ARBITRUM_RPC_URLS=
OPTIMISM_RPC_URLS=
POLYGON_RPC_URLS=
BSC_RPC_URLS=
RPC_STALL_TIMEOUT_MS=1500

# Etherscan API V2 key for automatic ABI fetching across supported chains.
ETHERSCAN_API_KEY=

# How often /confirmmint re-checks the contract while waiting for mint open time.
MINT_OPEN_POLL_MS=5000

# Optional SeaDrop overrides. Defaults are OpenSea SeaDrop + OpenSea fee recipient.
SEADROP_ADDRESS=
SEADROP_FEE_RECIPIENT=
SEADROP_OPEN_POLL_MS=5000
